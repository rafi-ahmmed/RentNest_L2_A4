{
   "compilerOptions": {
      "outDir": "./dist",
      "module": "nodenext",
      "target": "esnext",
      "types": ["node"],
      "sourceMap": true,
      "declaration": true,
      "declarationMap": true,
      "noUncheckedIndexedAccess": true,
      "strict": true,
      "isolatedModules": true,
      "noUncheckedSideEffectImports": true,
      "moduleDetection": "force",
      "skipLibCheck": true
   },
   //  "include": ["src/**/*"],
   // "exclude": ["node_modules", "dist","generated/prisma"]
   "exclude": ["node_modules", "dist"]
}
